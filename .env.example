# ── LLM Provider ──────────────────────────────────────────────────────────────
# Set LLM_PROVIDER to one of: groq | together | openrouter | ollama | huggingface | anthropic
LLM_PROVIDER=groq

# ── Groq (recommended — free tier, very fast, Llama/Mixtral) ──────────────────
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.1-70b-versatile

# ── Together AI ───────────────────────────────────────────────────────────────
TOGETHER_API_KEY=your_together_key_here
TOGETHER_MODEL=meta-llama/Llama-3-70b-chat-hf

# ── OpenRouter (100+ open-source models, OpenAI-compatible) ───────────────────
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=mistralai/mixtral-8x7b-instruct

# ── Ollama (local, no API key needed) ─────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── HuggingFace Inference API ─────────────────────────────────────────────────
HF_API_KEY=your_hf_token_here
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# ── Anthropic (optional) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6
